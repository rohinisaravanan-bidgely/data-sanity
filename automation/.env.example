# ── Databricks credentials ────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Workspace hostname — no "https://" prefix, no trailing slash
# Example: adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HOST=your-workspace.azuredatabricks.net

# Personal Access Token (Settings → Developer → Access Tokens)
DATABRICKS_TOKEN=dapi0000000000000000000000000000000

# SQL Warehouse ID — the short hex ID shown in the warehouse URL
# e.g. the URL  /sql/warehouses/abc123def456  → use  abc123def456
DATABRICKS_WAREHOUSE_ID=abc123def456

# ── Optional defaults ─────────────────────────────────────────────────────────
# Default catalog and schema used when no override is passed to run() / ask().
# If unset, these fall back to "hive_metastore" and "default".
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=default

# ── Anthropic API key (required for NL-to-SQL via ask() / translate()) ────────
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
